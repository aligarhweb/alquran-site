  lang="ur"
  dir="rtl"
  canonicalUrl="/ur/about/"
>
  <section class="page-section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="/ur/">صفحہ اول</a>
  <span>‹</span>
  <span>تعارف</span>
</nav>

<h1 class="page-title urdu-text">تعارف</h1>

      <!-- Tab Buttons -->
