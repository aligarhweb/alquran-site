<Layout
  title={t.title}
  description={t.description}
  lang="ur"
  dir="rtl"
  canonicalUrl="/ur/journal/"
>

  <!-- ═══════════════════════════════════════════════
       STICKY SECTION NAV
  ═══════════════════════════════════════════════ -->
  <nav class="section-nav" aria-label="صفحہ کے حصے">
    <div class="section-nav__inner">
      <a href="#archive" class="snav-link" data-target="archive">{t.navArchive}</a>
      <a href="#editorial" class="snav-link" data-target="editorial">{t.navEditorial}</a>
      <a href="#subscribe" class="snav-link" data-target="subscribe">{t.navSubscribe}</a>
      <a href="#contact" class="snav-link" data-target="contact">{t.navContact}</a>
    </div>
  </nav>

  <main class="page-main">

    <!-- ═══════════════════════════════════════════════
         BREADCRUMB
    ═══════════════════════════════════════════════ -->
    <nav class="breadcrumb" aria-label="بریڈکرمب">
      <a href="/ur/">{t.breadHome}</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{t.breadCurrent}</span>
    </nav>

    <!-- ═══════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════ -->
    <header class="journal-hero">
      <p class="journal-eyebrow">{t.heroEyebrow}</p>
      <h1 class="journal-title">{t.heroTitle}</h1>
      <p class="journal-subtitle">{t.heroSubtitle}</p>

      <ul class="credential-bar" aria-label="رسالے کی تفصیلات">
        <li class="credential">
          <span class="cred-value">1985</span>
          <span class="cred-label">{t.credEst}</span>
        </li>
        <li class="credential">
          <span class="cred-value">58</span>
          <span class="cred-label">{t.credIssues}</span>
        </li>
        <li class="credential">
          <span class="cred-value">ششماہی</span>
          <span class="cred-label">{t.credFrequency}</span>
        </li>
        <li class="credential">
          <span class="cred-value">نظریاتی جائزہ</span>
          <span class="cred-label">{t.credReview}</span>
        </li>
        <li class="credential">
          <span class="cred-value">اردو / انگریزی</span>
          <span class="cred-label">{t.credLang}</span>
        </li>
        <li class="credential">
          <span class="cred-value">آئی ایس ایس این جاری</span>
          <span class="cred-label">{t.credIssn}</span>
        </li>
      </ul>
    </header>

