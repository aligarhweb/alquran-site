const latestIssues = [...issues].reverse().slice(0, 3);

// Build year‑grouped archive
type Issue = typeof issues[0];
const issuesByYear: Record<string, Issue[]> = {};
for (const issue of [...issues].reverse()) {
  const yearMatch = issue.period.match(/\d{4}/g);
  const year = yearMatch ? yearMatch[yearMatch.length - 1] : 'Unknown';
  if (!issuesByYear[year]) issuesByYear[year] = [];
  issuesByYear[year].push(issue);
}
const yearGroups = Object.entries(issuesByYear).sort((a, b) => Number(b[0]) - Number(a[0]));

