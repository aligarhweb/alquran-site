  --container-max: 920px;
  --container-pad: clamp(1rem, 4vw, 2.5rem);
  --header-height: 75px; /* adjust to your sticky header */
}

/* ─── RESET ────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:focus-visible {
  outline: 3px solid var(--c-teal);
  outline-offset: 3px;
  border-radius: 2px;
}

/* ─── STICKY SECTION NAV ──────────────────────────── */
.section-nav {
  position: sticky;
  top: calc(var(--header-height) + 30px); /* header height + offset */
  z-index: 99;
  background: var(--c-bg);
  border-bottom: 1px solid var(--c-border);
  box-shadow: 0 2px 6px rgba(0,0,0,0.05);
}

.section-nav__inner {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--container-pad);
  display: flex;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
}
.section-nav__inner::-webkit-scrollbar { display: none; }

.snav-link {
  display: inline-block;
  padding: 0.7rem 1.1rem;
  font-family: var(--font-sans);
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: var(--c-muted);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
}
.snav-link:hover { color: var(--c-ink); text-decoration: none; }
.snav-link--active {
  color: var(--c-teal);
  border-bottom-color: var(--c-teal);
}

/* ─── PAGE LAYOUT ─────────────────────────────────── */
.page-main {
