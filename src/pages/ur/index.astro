---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="قرآنی تحقیق — 1984 سے"
  description="ادارہ علوم القرآن، علی گڑھ مسلم یونیورسٹی میں 1984 میں قائم ایک علمی ادارہ ہے جو قرآنی علوم کی تحقیق اور اشاعت کے لیے وقف ہے۔"
  lang="ur"
  dir="rtl"
  canonicalUrl="/ur/"
>
  <!-- JSON‑LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "ادارہ علوم القرآن",
    "alternateName": "Idara Ulum-Al-Qur'an",
    "foundingDate": "1984",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "علی گڑھ",
      "addressCountry": "IN"
    },
    "url": "https://example.com/ur/",
    "sameAs": [
      "https://example.com/ur/journal/"
    ]
  })} />
  <!-- ─── Hero ─── -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">1984 · علی گڑھ مسلم یونیورسٹی</p>
        <h1 id="hero-heading" class="hero-heading urdu-text">ادارہ علوم القرآن</h1>
        <p class="hero-sub urdu-text">
          قرآن مجید خالق کائنات کی طرف سے انسانیت کے لیے آخری صحیفہ ہدایت ہے۔
          اس احساس کے پیش نظر اللہ تعالیٰ کی توفیق و مدد سے 1984 میں ادارہ علوم القرآن
          کا قیام عمل میں آیا۔ ادارہ قرآنی علوم کی تحقیق، قرآن کریم کی تعلیمات کے فروغ
          اور مسائل کا قرآن کی روشنی میں حل تلاش کرنے کے لیے وقف ہے۔
        </p>
        <div class="hero-actions">
          <a href="/ur/journal/" class="btn-primary" aria-label="رسالہ پڑھیں">رسالہ پڑھیں</a>
          <a href="/ur/about/" class="btn-secondary" aria-label="مزید جانیں">مزید جانیں</a>
        </div>
      </div>

      <ul class="hero-stats" role="list">
        <li class="stat-card">
          <span class="stat-number">58</span>
          <span class="stat-label urdu-text">شمارے</span>
        </li>
        <li class="stat-card">
          <span class="stat-number">40+</span>
          <span class="stat-label urdu-text">سال کی تحقیق</span>
        </li>
        <li class="stat-card">
          <span class="stat-number">1984</span>
          <span class="stat-label urdu-text">سنۂ تاسیس</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ─── Journal Spotlight ─── -->
  <section class="journal-spotlight" aria-labelledby="spotlight-heading">
    <div class="container spotlight-inner">
      <div class="spotlight-badge urdu-text">تازہ ترین شمارہ</div>
      <div class="spotlight-content">
        <div class="spotlight-meta">
          <span class="journal-title">
            <span class="urdu-text">علوم القرآن</span> — <span class="latin-text">Ulum al-Qur'an</span>
          </span>
          <h2 id="spotlight-heading" class="spotlight-heading urdu-text">شمارہ 58 · جولائی–دسمبر 2024</h2>
          <p class="spotlight-desc urdu-text">
            علوم القرآن ایک مستند علمی رسالہ ہے جو ادارہ علوم القرآن کی جانب سے 1985 سے
            سال میں دو بار شائع ہوتا ہے۔ اس میں قرآنی علوم، تفسیر اور متعلقہ موضوعات پر
            اصیل تحقیقی مقالات شائع کیے جاتے ہیں۔
          </p>
          <div class="spotlight-actions">
            <a href="https://drive.google.com/file/d/1_0a8NqZbG4WZGfWl1niWfHK_rlyx39Gi/view?usp=drive_link" target="_blank" rel="noopener" class="btn-primary" aria-label="آن لائن پڑھیں">آن لائن پڑھیں</a>
            <a href="/ur/journal/" class="btn-outline" aria-label="تمام شمارے">تمام شمارے</a>
          </div>
        </div>
        <div class="spotlight-cover">
          <img 
            src="/images/journal-cover-58.jpg" 
            alt="علوم القرآن شمارہ 58 کا سرورق"
            width="220" 
            height="300"
            class="cover-image"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Recent Publications ─── -->
  <section class="publications-section" aria-labelledby="pub-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="pub-heading" class="section-title urdu-text">حالیہ اشاعتیں</h2>
        <a href="/ur/publications/" class="section-link" aria-label="تمام اشاعتیں دیکھیں">← تمام اشاعتیں </a>
      </div>
      <ul class="pub-grid" role="list">
        <li class="pub-card">
          <div class="pub-cover" aria-hidden="true">
            <span class="pub-cover-urdu urdu-text">خاندانی نظام</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title"><a href="/ur/publications/"><span class="urdu-text">خاندانی نظام اور قرآنی تعلیمات</span></a></h3>
            <p class="pub-title-en latin-text">Family System and Qur'anic Teachings</p>
            <p class="pub-meta"><span class="urdu-text">اشتیاق احمد ظلی · 2010 · 392 صفحات</span></p>
          </div>
        </li>
        <li class="pub-card">
          <div class="pub-cover" aria-hidden="true">
            <span class="pub-cover-urdu urdu-text">مبادی تدبر</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title"><a href="/ur/publications/"><span class="urdu-text">مبادی تدبرِ قرآن</span></a></h3>
            <p class="pub-title-en latin-text">Principles of Qur'anic Contemplation</p>
            <p class="pub-meta"><span class="urdu-text">امین احسن اصلاحی · 2016 · 280 صفحات</span></p>
          </div>
        </li>
        <li class="pub-card">
          <div class="pub-cover" aria-hidden="true">
            <span class="pub-cover-urdu urdu-text">سماجی برائیاں</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title"><a href="/ur/publications/"><span class="urdu-text">سماجی برائیوں کا انسداد اور قرآنی تعلیمات</span></a></h3>
            <p class="pub-title-en latin-text">How to Abolish Social Evils in the Light of the Qur'an</p>
            <p class="pub-meta"><span class="urdu-text">اشہد رفیق ندوی · 2014 · 440 صفحات</span></p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ─── About Strip ─── -->
  <section class="about-strip" aria-labelledby="about-heading">
    <div class="container about-inner">
      <div class="about-text">
        <h2 id="about-heading" class="urdu-text">ادارے کے بارے میں</h2>
        <p class="urdu-text">
         ادارہ علوم القرآن 1984ء میں قرآنِ کریم کے علوم و معارف کی اشاعت، تحقیق، تدریس اور تفہیم کے مقصد سے قائم کیا گیا۔ ادارہ قرآنی تعلیمات کی روشنی میں فکری و عملی رہنمائی کے لیے مسلسل سرگرمِ عمل ہے۔ اس کا مرکزی دفتر شبلی باغ، علی گڑھ میں واقع ہے۔
        </p>
        <a href="/ur/about/" class="btn-outline" aria-label="مکمل تعارف پڑھیں">مکمل تعارف پڑھیں ←</a>
      </div>
      <ul class="about-numbers" role="list">
        <li class="about-stat">
          <span class="about-num">1984</span>
          <span class="about-lbl urdu-text">سنۂ تاسیس</span>
        </li>
        <li class="about-stat">
          <span class="about-num">58</span>
          <span class="about-lbl urdu-text">شمارے</span>
        </li>
        <li class="about-stat">
          <span class="about-num">2</span>
          <span class="about-lbl urdu-text">زبانوں میں</span>
        </li>
      </ul>
    </div>
  </section>

</Layout>

<style>
/* ─── Base Fonts ─── */
body, .container {
  direction: rtl;
  text-align: right;
  font-family: 'Source Serif 4', 'Times New Roman', serif;
}

.urdu-text {
  font-family: 'Noto Nastaliq Urdu', 'Urdu Typesetting', serif;
  line-height: 2;
}

.latin-text {
  font-family: 'Source Serif 4', 'Times New Roman', serif;
}

/* ─── Hero ─── */
.hero {
  background: linear-gradient(135deg, var(--color-primary) 0%, #0d3d32 100%);
  color: #FFFFFF;
  padding: 5rem 0 4rem;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: center;
}

.hero-eyebrow {
  font-size: 0.9rem;
  letter-spacing: 0.04em;
  color: var(--color-accent);
  margin-bottom: 1rem;
}

.hero-heading {
  font-size: 2.75rem;
  color: #FFFFFF;
  margin-bottom: 1.5rem;
}

.hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.82);
  max-width: 560px;
  margin-bottom: 2rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.btn-primary {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  background: var(--color-accent);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 1rem;
  transition: background 0.2s, transform 0.15s;
  text-decoration: none;
}

.btn-primary:hover {
  background: color-mix(in srgb, var(--color-accent) 85%, #000);
  transform: scale(1.02);
  text-decoration: none;
}

.btn-secondary {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  border: 2px solid rgba(255,255,255,0.5);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 1rem;
  transition: border-color 0.2s, background 0.2s;
  text-decoration: none;
}

.btn-secondary:hover {
  border-color: #FFFFFF;
  background: rgba(255,255,255,0.1);
  text-decoration: none;
}

.btn-outline {
  display: inline-block;
  padding: 0.65rem 1.4rem;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 4px;
  font-weight: 600;
  font-size: 1rem;
  transition: background 0.2s, color 0.2s, transform 0.15s;
  text-decoration: none;
}

.btn-outline:hover {
  background: var(--color-primary);
  color: #FFFFFF;
  transform: scale(1.02);
  text-decoration: none;
}

/* Hero Stats – no bullets */
.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.stat-card {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  padding: 1.25rem 2rem;
  text-align: center;
  min-width: 160px;
}

.stat-number {
  display: block;
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--color-accent);
  line-height: 1;
  margin-bottom: 0.4rem;
  font-family: 'Source Serif 4', serif;
}

.stat-label {
  display: block;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.7);
}

/* ─── Journal Spotlight ─── */
.journal-spotlight {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  padding: 3.5rem 0;
}

.spotlight-badge {
  display: inline-block;
  background: var(--color-accent);
  color: #FFFFFF;
  font-size: 0.85rem;
  font-weight: 700;
  padding: 0.3rem 0.9rem;
  border-radius: 20px;
  margin-bottom: 1.5rem;
}

.spotlight-content {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: center;
}

.journal-title {
  display: block;
  font-size: 0.9rem;
  color: var(--color-muted);
  margin-bottom: 0.5rem;
}

.spotlight-heading {
  font-size: 2rem;
  color: var(--color-primary);
  margin-bottom: 1rem;
}

.spotlight-desc {
  font-size: 1rem;
  color: var(--color-muted);
  max-width: 520px;
  margin-bottom: 1.75rem;
}

.spotlight-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.cover-image {
  width: 220px;
  height: 300px;
  border-radius: 6px;
  object-fit: cover;
  box-shadow: 0 8px 24px rgba(27,94,79,0.25);
  display: block;
  background: #0d3d32;
}

/* ─── Publications ─── */
.publications-section {
  padding: 4rem 0;
  background: var(--color-bg);
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 2rem;
  border-bottom: 2px solid var(--color-border);
  padding-bottom: 1rem;
}

.section-title {
  font-size: 1.5rem;
  color: var(--color-primary);
}

.section-link {
  font-size: 0.95rem;
  color: var(--color-link);
  font-weight: 600;
  text-decoration: none;
}

.section-link:hover {
  text-decoration: underline;
}

.pub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.pub-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  overflow: hidden;
  transition: box-shadow 0.2s, transform 0.15s;
}

.pub-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  transform: translateY(-4px);
}

.pub-cover {
  background: linear-gradient(160deg, var(--color-primary) 0%, #0d3d32 100%);
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pub-cover-urdu {
  font-size: 1.3rem;
  color: var(--color-accent);
  text-align: center;
}

.pub-info {
  padding: 1.25rem;
}

.pub-title {
  font-size: 1rem;
  margin-bottom: 0.35rem;
}

.pub-title a {
  color: var(--color-primary);
  text-decoration: none;
}

.pub-title a:hover {
  text-decoration: underline;
}

.pub-title-en {
  font-size: 0.8rem;
  color: var(--color-muted);
  font-style: italic;
  margin-bottom: 0.75rem;
  direction: ltr;
  text-align: left;
}

.pub-meta {
  font-size: 0.85rem;
  color: var(--color-muted);
}

/* ─── About Strip ─── */
.about-strip {
  background: var(--color-white);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 4rem 0;
}

.about-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
}

.about-text h2 {
  font-size: 1.75rem;
  color: var(--color-primary);
  margin-bottom: 1rem;
}

.about-text p {
  font-size: 1rem;
  color: var(--color-muted);
  max-width: 580px;
  margin-bottom: 1.5rem;
}

.about-text em {
  color: var(--color-primary);
  font-style: normal;
}

.about-numbers {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin: 0;
  padding: 0;
  list-style: none;
  border-inline-end: 2px solid var(--color-border);
  padding-inline-end: 3rem;
}

.about-stat {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  text-align: center;
}

.about-num {
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
  font-family: 'Source Serif 4', serif;
}

.about-lbl {
  font-size: 0.85rem;
  color: var(--color-muted);
}

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .hero {
    padding: 2.5rem 0 2rem;
  }

  .hero-inner {
    display: block;
  }

  .hero-heading {
    font-size: 1.9rem;
  }

  .hero-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .btn-primary,
  .btn-secondary,
  .btn-outline {
    text-align: center;
  }

  .hero-stats {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .stat-card {
    flex: 1 1 calc(33% - 0.75rem);
    min-width: 85px;
    padding: 0.85rem 0.5rem;
  }

  .spotlight-content {
    display: block;
  }

  .spotlight-heading {
    font-size: 1.4rem;
  }

  .cover-image {
    width: 160px;
    height: 220px;
    margin: 1.5rem auto 0;
  }

  .spotlight-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .pub-grid {
    grid-template-columns: 1fr;
  }

  .about-inner {
    display: block;
  }

  .about-numbers {
    flex-direction: row;
    flex-wrap: wrap;
    border-inline-end: none;
    padding-inline-end: 0;
    border-top: 2px solid var(--color-border);
    margin-top: 2rem;
    padding-top: 1.5rem;
    gap: 2rem;
    justify-content: space-around;
  }
}
</style>