---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="قرآنی تحقیق — 1984 سے"
  description="ادارہ علوم القرآن، علی گڑھ مسلم یونیورسٹی میں 1984 میں قائم ایک علمی ادارہ ہے جو قرآنی علوم کی تحقیق اور اشاعت کے لیے وقف ہے۔"
  lang="ur"
  dir="rtl"
  canonicalUrl="/ur/"
>

  <!-- ─── Hero ─── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">1984 · علی گڑھ مسلم یونیورسٹی</p>
        <h1 class="hero-heading">ادارہ علوم القرآن</h1>
        <p class="hero-sub">
          قرآن مجید خالق کائنات کی طرف سے انسانیت کے لیے آخری صحیفہ ہدایت ہے۔
          اس احساس کے پیش نظر اللہ تعالیٰ کی توفیق و مدد سے 1984 میں ادارہ علوم القرآن
          کا قیام عمل میں آیا۔ ادارہ قرآنی علوم کی تحقیق، قرآن کریم کی تعلیمات کے فروغ
          اور مسائل کا قرآن کی روشنی میں حل تلاش کرنے کے لیے وقف ہے۔
        </p>
        <div class="hero-actions">
          <a href="/en/journal/" class="btn-primary">رسالہ پڑھیں</a>
          <a href="/en/about/" class="btn-secondary">مزید جانیں</a>
        </div>
      </div>

      <div class="hero-stats">
        <div class="stat-card">
          <span class="stat-number">58</span>
          <span class="stat-label">شمارے</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">40+</span>
          <span class="stat-label">سال کی تحقیق</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1984</span>
          <span class="stat-label">سنۂ تاسیس</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Journal Spotlight ─── -->
  <section class="journal-spotlight">
    <div class="container spotlight-inner">
      <div class="spotlight-badge">تازہ ترین شمارہ</div>
      <div class="spotlight-content">
        <div class="spotlight-meta">
          <span class="journal-title">علوم القرآن — Ulum al-Qur'an</span>
          <h2 class="spotlight-heading">شمارہ 58 · جولائی–دسمبر 2024</h2>
          <p class="spotlight-desc">
            علوم القرآن ایک مستند علمی رسالہ ہے جو ادارہ علوم القرآن کی جانب سے 1985 سے
            سال میں دو بار شائع ہوتا ہے۔ اس میں قرآنی علوم، تفسیر اور متعلقہ موضوعات پر
            اصیل تحقیقی مقالات شائع کیے جاتے ہیں۔
          </p>
          <div class="spotlight-actions">
            <a href="https://drive.google.com/file/d/1_0a8NqZbG4WZGfWl1niWfHK_rlyx39Gi/view?usp=drive_link" target="_blank" rel="noopener" class="btn-primary">آن لائن پڑھیں</a>
            <a href="/en/journal/" class="btn-outline">تمام شمارے</a>
          </div>
        </div>
        <div class="spotlight-cover">
          <div class="cover-placeholder">
            <span class="cover-urdu">علوم القرآن</span>
            <span class="cover-vol">شمارہ 58</span>
            <span class="cover-year">2024</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Recent Publications ─── -->
  <section class="publications-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">حالیہ اشاعتیں</h2>
        <a href="/en/publications/" class="section-link">تمام اشاعتیں ←</a>
      </div>
      <div class="pub-grid">
        <article class="pub-card">
          <div class="pub-cover">
            <span class="pub-cover-urdu">خاندانی نظام</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title"><a href="/en/publications/">خاندانی نظام اور قرآنی تعلیمات</a></h3>
            <p class="pub-title-en">Family System and Qur'anic Teachings</p>
            <p class="pub-meta">اشتیاق احمد ظلی · 2010 · 392 صفحات</p>
          </div>
        </article>
        <article class="pub-card">
          <div class="pub-cover">
            <span class="pub-cover-urdu">مبادی تدبر</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title"><a href="/en/publications/">مبادی تدبرِ قرآن</a></h3>
            <p class="pub-title-en">Principles of Qur'anic Contemplation</p>
            <p class="pub-meta">امین احسن اصلاحی · 2016 · 280 صفحات</p>
          </div>
        </article>
        <article class="pub-card">
          <div class="pub-cover">
            <span class="pub-cover-urdu">سماجی برائیاں</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title"><a href="/en/publications/">سماجی برائیوں کا انسداد اور قرآنی تعلیمات</a></h3>
            <p class="pub-title-en">How to Abolish Social Evils in the Light of the Qur'an</p>
            <p class="pub-meta">اشہد رفیق ندوی · 2014 · 440 صفحات</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ─── About Strip ─── -->
  <section class="about-strip">
    <div class="container about-inner">
      <div class="about-text">
        <h2>ادارے کے بارے میں</h2>
        <p>
          ادارہ علوم القرآن 1984 میں علی گڑھ مسلم یونیورسٹی میں قائم کیا گیا۔
          یہ ادارہ امام حمید الدین فراہی اور مولانا امین احسن اصلاحی کی علمی روایت پر
          قرآنی علوم میں تحقیق و اشاعت کا کام انجام دیتا ہے۔ ادارہ ششماہی رسالہ 
          <em> علوم القرآن </em> شائع کرتا ہے، سیمینار منعقد کرتا ہے اور مقابلے
          کا اہتمام کرتا ہے۔
        </p>
        <a href="/en/about/" class="btn-outline">مکمل تعارف پڑھیں ←</a>
      </div>
      <div class="about-numbers">
        <div class="about-stat">
          <span class="about-num">1984</span>
          <span class="about-lbl">سنۂ تاسیس</span>
        </div>
        <div class="about-stat">
          <span class="about-num">58</span>
          <span class="about-lbl">شمارے</span>
        </div>
        <div class="about-stat">
          <span class="about-num">3</span>
          <span class="about-lbl">زبانیں</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ─── RTL Base ─── */
.container {
  direction: rtl;
  text-align: right;
  font-family: 'Noto Nastaliq Urdu', serif;
}

/* ─── Hero ─── */
.hero {
  background: linear-gradient(135deg, var(--color-primary) 0%, #0d3d32 100%);
  color: #FFFFFF;
  padding: 5rem 0 4rem;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: center;
}

.hero-eyebrow {
  font-size: 0.9rem;
  letter-spacing: 0.04em;
  color: var(--color-accent);
  margin-bottom: 1rem;
}

.hero-heading {
  font-size: 2.75rem;
  color: #FFFFFF;
  line-height: 2;
  margin-bottom: 1.5rem;
}

.hero-sub {
  font-size: 1.1rem;
  line-height: 2.2;
  color: rgba(255,255,255,0.82);
  max-width: 560px;
  margin-bottom: 2rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.btn-primary {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  background: var(--color-accent);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 1rem;
  line-height: 2;
  transition: opacity 0.2s;
}

.btn-primary:hover {
  opacity: 0.88;
  text-decoration: none;
}

.btn-secondary {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  border: 2px solid rgba(255,255,255,0.5);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 1rem;
  line-height: 2;
  transition: border-color 0.2s;
}

.btn-secondary:hover {
  border-color: #FFFFFF;
  text-decoration: none;
}

.btn-outline {
  display: inline-block;
  padding: 0.65rem 1.4rem;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 4px;
  font-weight: 600;
  font-size: 1rem;
  line-height: 2;
  transition: background 0.2s, color 0.2s;
}

.btn-outline:hover {
  background: var(--color-primary);
  color: #FFFFFF;
  text-decoration: none;
}

/* Hero Stats */
.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.stat-card {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  padding: 1.25rem 2rem;
  text-align: center;
  min-width: 160px;
}

.stat-number {
  display: block;
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--color-accent);
  line-height: 1;
  margin-bottom: 0.4rem;
  font-family: 'Source Serif 4', serif;
}

.stat-label {
  display: block;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.7);
  line-height: 1.8;
}

/* ─── Journal Spotlight ─── */
.journal-spotlight {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  padding: 3.5rem 0;
}

.spotlight-badge {
  display: inline-block;
  background: var(--color-accent);
  color: #FFFFFF;
  font-size: 0.85rem;
  font-weight: 700;
  padding: 0.3rem 0.9rem;
  border-radius: 20px;
  margin-bottom: 1.5rem;
  line-height: 2;
}

.spotlight-content {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: center;
}

.journal-title {
  display: block;
  font-size: 0.9rem;
  color: var(--color-muted);
  margin-bottom: 0.5rem;
}

.spotlight-heading {
  font-size: 2rem;
  color: var(--color-primary);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.spotlight-desc {
  font-size: 1rem;
  line-height: 2.2;
  color: var(--color-muted);
  max-width: 520px;
  margin-bottom: 1.75rem;
}

.spotlight-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.cover-placeholder {
  width: 180px;
  height: 240px;
  background: linear-gradient(160deg, var(--color-primary) 0%, #0d3d32 100%);
  border-radius: 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  box-shadow: 0 8px 24px rgba(27,94,79,0.25);
}

.cover-urdu {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1.4rem;
  color: var(--color-accent);
  line-height: 2;
}

.cover-vol {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
}

.cover-year {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.55);
}

/* ─── Publications ─── */
.publications-section {
  padding: 4rem 0;
  background: var(--color-bg);
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 2rem;
  border-bottom: 2px solid var(--color-border);
  padding-bottom: 1rem;
}

.section-title {
  font-size: 1.5rem;
  color: var(--color-primary);
  line-height: 1.8;
}

.section-link {
  font-size: 0.95rem;
  color: var(--color-link);
  font-weight: 600;
  line-height: 2;
}

.pub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.pub-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}

.pub-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}

.pub-cover {
  background: linear-gradient(160deg, var(--color-primary) 0%, #0d3d32 100%);
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pub-cover-urdu {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1.3rem;
  color: var(--color-accent);
  line-height: 2;
  text-align: center;
}

.pub-info {
  padding: 1.25rem;
}

.pub-title {
  font-size: 1rem;
  line-height: 1.8;
  margin-bottom: 0.35rem;
}

.pub-title a {
  color: var(--color-primary);
}

.pub-title a:hover {
  text-decoration: underline;
}

.pub-title-en {
  font-size: 0.8rem;
  color: var(--color-muted);
  font-style: italic;
  margin-bottom: 0.75rem;
  font-family: 'Source Serif 4', serif;
  direction: ltr;
  text-align: left;
}

.pub-meta {
  font-size: 0.85rem;
  color: var(--color-muted);
  line-height: 1.8;
}

/* ─── About Strip ─── */
.about-strip {
  background: var(--color-white);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 4rem 0;
}

.about-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
}

.about-text h2 {
  font-size: 1.75rem;
  color: var(--color-primary);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.about-text p {
  font-size: 1rem;
  line-height: 2.2;
  color: var(--color-muted);
  max-width: 580px;
  margin-bottom: 1.5rem;
}

.about-text em {
  color: var(--color-primary);
  font-style: normal;
}

.about-numbers {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  border-right: 2px solid var(--color-border);
  padding-right: 3rem;
}

.about-stat {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  text-align: center;
}

.about-num {
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
  font-family: 'Source Serif 4', serif;
}

.about-lbl {
  font-size: 0.85rem;
  color: var(--color-muted);
  line-height: 1.8;
}

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .hero {
    padding: 2.5rem 0 2rem;
  }

  .hero-inner {
    display: block;
  }

  .hero-heading {
    font-size: 1.9rem;
  }

  .hero-actions {
    justify-content: stretch;
    flex-direction: column;
  }

  .btn-primary,
  .btn-secondary {
    text-align: center;
  }

  .hero-stats {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .stat-card {
    flex: 1 1 calc(33% - 0.75rem);
    min-width: 85px;
    padding: 0.85rem 0.5rem;
  }

  .spotlight-content {
    display: block;
  }

  .spotlight-heading {
    font-size: 1.4rem;
  }

  .cover-placeholder {
    width: 120px;
    height: 160px;
    margin: 1.5rem auto 0;
  }

  .spotlight-actions {
    justify-content: stretch;
    flex-direction: column;
  }

  .pub-grid {
    grid-template-columns: 1fr;
  }

  .about-inner {
    display: block;
  }

  .about-numbers {
    flex-direction: row;
    flex-wrap: wrap;
    border-right: none;
    padding-right: 0;
    border-top: 2px solid var(--color-border);
    margin-top: 2rem;
    padding-top: 1.5rem;
    gap: 2rem;
    justify-content: space-around;
  }
}
</style>