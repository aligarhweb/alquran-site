// Generate JSON-LD Schema (with localized digit parsing)
const schemaData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": publications.map((pub, index) => {
    const bookSchema = {
      "@type": "Book",
      "name": pub.title,
      "alternateName": pub.titleEn, 
      "description": pub.desc,
      "inLanguage": "ur"
    };

    if (pub.editors) {
      bookSchema.author = { "@type": "Person", "name": pub.editors };
    }

    if (pub.year) {
      const cleanYear = String(pub.year).match(/\d{4}/);
      if (cleanYear) bookSchema.datePublished = cleanYear[0];
    }

    if (pub.pages) {
      const parsedPages = urduToEnglishDigits(pub.pages);
      if (parsedPages) bookSchema.numberOfPages = parsedPages;
    }

    if (pub.price) {
      const priceMatch = urduToEnglishDigits(pub.price);
      if (priceMatch) {
        bookSchema.offers = {
          "@type": "Offer",
          "price": priceMatch,
          "priceCurrency": "INR"
        };
      }
    }

    return {
      "@type": "ListItem",
      "position": index + 1,
      "item": bookSchema
    };
  })
};
