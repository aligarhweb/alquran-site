// Helper to convert Urdu digits to English digits for strict Schema compliance
const urduToEnglishDigits = (str) => {
  if (!str) return null;
  const converted = str.replace(/[۰-۹]/g, d => "۰۱۲۳۴۵۶۷۸۹".indexOf(d));
  const match = converted.match(/\d+/);
  return match ? match[0] : null;
};

