<!-- ═══════════════════════════════════════════════════════════════
     JAVASCRIPT: Search, Decade filter, Sticky nav, Copy buttons
═══════════════════════════════════════════════════════════════ -->
<script>
(function () {
  /* ── Sticky section nav active state ── */
  const snavLinks = document.querySelectorAll('.snav-link');
  const sections  = Array.from(snavLinks).map(l => document.getElementById(l.dataset.target ?? ''));

  function updateActiveLink() {
    let active = sections[0];
    const scrollY = window.scrollY + 120;
    for (const section of sections) {
      if (section && section.offsetTop <= scrollY) active = section;
    }
    snavLinks.forEach(l => {
      l.classList.toggle('snav-link--active', l.dataset.target === active?.id);
    });
  }

  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  /* ── Search & filter ── */
  const searchInput = document.getElementById('issueSearch') as HTMLInputElement | null;
  const filterBtns  = document.querySelectorAll('.filter-btn');
  const cards       = document.querySelectorAll('.issue-card') as NodeListOf<HTMLElement>;
  const yearGroups  = document.querySelectorAll('.year-group') as NodeListOf<HTMLElement>;
  const emptyMsg    = document.getElementById('archive-empty');

  let currentQuery  = '';
  let currentDecade = 'all';

  function matchesDecade(card: HTMLElement, decade: string): boolean {
    if (decade === 'all') return true;
    if (decade === 'special') return card.dataset.special === 'true';
    const period = card.dataset.period ?? '';
    const years = period.match(/\d{4}/g);
    if (!years) return false;
    return years.some(y => Math.floor(Number(y) / 10) * 10 === Number(decade));
  }

  function applyFilters() {
    let visibleCount = 0;

    cards.forEach(card => {
      const text    = card.dataset.search ?? '';
      const matchQ  = !currentQuery || text.includes(currentQuery);
      const matchD  = matchesDecade(card, currentDecade);
      const visible = matchQ && matchD;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Hide year headings that have no visible children
    yearGroups.forEach(group => {
      const groupCards = group.querySelectorAll('.issue-card') as NodeListOf<HTMLElement>;
      const anyVisible = Array.from(groupCards).some(c => c.style.display !== 'none');
      (group as HTMLElement).style.display = anyVisible ? '' : 'none';
    });

    if (emptyMsg) {
      emptyMsg.hidden = visibleCount > 0;
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      currentQuery = searchInput.value.trim().toLowerCase();
      applyFilters();
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      currentDecade = (btn as HTMLElement).dataset.decade ?? 'all';
      applyFilters();
    });
  });

  /* ── Copy to clipboard buttons ── */
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const targetId = (btn as HTMLElement).dataset.copy;
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const text = el.textContent?.trim() ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Copied';
        btn.setAttribute('aria-label', 'Copied!');
        setTimeout(() => {
          btn.innerHTML = originalHTML;
          btn.setAttribute('aria-label', `Copy ${text}`);
        }, 2000);
      } catch {
        // Fallback — silently fail
      }
    });
  });
})();
</script>


