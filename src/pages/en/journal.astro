const latestIssues = [...issues].reverse().slice(0, 3);

// Build year-grouped archive for server-side rendering
// Groups are sorted descending by year; within each group, issues are descending by issue number.
type Issue = typeof issues[0];
const issuesByYear: Record<string, Issue[]> = {};
for (const issue of [...issues].reverse()) {
  // Extract the last year from the period string (handles spans like "July 2007 – June 2009")
  const yearMatch = issue.period.match(/\d{4}/g);
  const year = yearMatch ? yearMatch[yearMatch.length - 1] : 'Unknown';
  if (!issuesByYear[year]) issuesByYear[year] = [];
  issuesByYear[year].push(issue);
}
const yearGroups = Object.entries(issuesByYear).sort((a, b) => Number(b[0]) - Number(a[0]));
---

<Layout
  title="Biannual Journal — Ulum al-Qur'an"
  description="Ulum al-Qur'an is a peer-reviewed biannual journal published by Idara Ulum-Al-Qur'an since 1985. Browse and read all 58 issues online."
  canonicalUrl="/en/journal/"
>

  <!-- ═══════════════════════════════════════════════
       STICKY SECTION NAV
  ═══════════════════════════════════════════════ -->
  <nav class="section-nav" aria-label="Page sections">
    <div class="section-nav__inner">
      <a href="#archive" class="snav-link" data-target="archive">Archive</a>
      <a href="#editorial" class="snav-link" data-target="editorial">Editorial Board</a>
      <a href="#subscribe" class="snav-link" data-target="subscribe">Subscribe</a>
      <a href="#contact" class="snav-link" data-target="contact">Contact</a>
    </div>
  </nav>

  <main class="page-main">

    <!-- ═══════════════════════════════════════════════
         BREADCRUMB
    ═══════════════════════════════════════════════ -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/en/">Home</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Journal</span>
    </nav>

    <!-- ═══════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════ -->
    <header class="journal-hero">
      <p class="journal-eyebrow">Idarah Ulum al-Qur'an, Aligarh</p>
      <h1 class="journal-title">Ulum al-Qur'an</h1>
      <p class="journal-subtitle">A peer-reviewed biannual journal dedicated to Qur'anic sciences and Islamic scholarship, published continuously since 1985.</p>

      <ul class="credential-bar" aria-label="Journal credentials">
        <li class="credential">
          <span class="cred-value">1985</span>
          <span class="cred-label">Est.</span>
        </li>
        <li class="credential">
          <span class="cred-value">58</span>
          <span class="cred-label">Issues</span>
        </li>
        <li class="credential">
          <span class="cred-value">Biannual</span>
          <span class="cred-label">Frequency</span>
        </li>
        <li class="credential">
          <span class="cred-value">Peer Reviewed</span>
          <span class="cred-label">Review Type</span>
        </li>
        <li class="credential">
          <span class="cred-value">Urdu / English</span>
          <span class="cred-label">Language</span>
        </li>
        <li class="credential">
          <span class="cred-value">ISSN TBC</span>
          <span class="cred-label">ISSN</span>
        </li>
      </ul>
    </header>

    <!-- ═══════════════════════════════════════════════
         LATEST ISSUES
    ═══════════════════════════════════════════════ -->
    <section class="latest-section" aria-labelledby="latest-heading">
      <h2 id="latest-heading" class="section-heading">Latest Issues</h2>
      <div class="latest-grid">
        {latestIssues.map((issue, i) => (
          <a
            href={issue.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`latest-card${i === 0 ? ' latest-card--primary' : ''}${issue.special ? ' latest-card--special' : ''}`}
            aria-label={`Read Issue ${issue.no} (${issue.period}) PDF — opens in a new tab`}
          >
            {issue.special && (
              <span class="special-badge" aria-label="Special edition">
                <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" focusable="false">
                  <polygon points="5,0 6.18,3.82 10,3.82 6.91,6.18 8.09,10 5,7.64 1.91,10 3.09,6.18 0,3.82 3.82,3.82" fill="currentColor"/>
                </svg>
                Special Edition
              </span>
            )}
            <span class="lc-number">Issue {issue.no}</span>
            <span class="lc-period">{issue.period}</span>
            {issue.special && issue.specialNote && (
              <span class="lc-special-note">{issue.specialNote}</span>
            )}
            <span class="lc-cta" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
              </svg>
              Read PDF
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         ARCHIVE: SEARCH + FILTERS + GROUPED ISSUES
    ═══════════════════════════════════════════════ -->
    <section id="archive" class="archive-section" aria-labelledby="archive-heading">
      <h2 id="archive-heading" class="section-heading">Complete Archive</h2>
      <p class="section-intro">All 58 issues of <em>Ulum al-Qur'an</em> from 1985 to 2024. Each PDF opens in a new tab.</p>

      <!-- Search -->
      <div class="archive-controls">
        <div class="search-wrap">
          <label for="issueSearch" class="search-label">Search issues</label>
          <div class="search-field-wrap">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              id="issueSearch"
              type="search"
              class="search-input"
              placeholder="Issue number, year, or title…"
              autocomplete="off"
              spellcheck="false"
            />
          </div>
        </div>

        <!-- Decade filters -->
        <div class="filter-wrap" role="group" aria-label="Filter by decade">
          <button class="filter-btn filter-btn--active" data-decade="all" type="button">All</button>
          <button class="filter-btn" data-decade="1980" type="button">1980s</button>
          <button class="filter-btn" data-decade="1990" type="button">1990s</button>
          <button class="filter-btn" data-decade="2000" type="button">2000s</button>
          <button class="filter-btn" data-decade="2010" type="button">2010s</button>
          <button class="filter-btn" data-decade="2020" type="button">2020s</button>
          <button class="filter-btn" data-decade="special" type="button">Special Issues</button>
        </div>
      </div>

      <!-- No results message -->
      <p id="archive-empty" class="archive-empty" hidden aria-live="polite">No issues match your search.</p>

      <!-- Grouped archive -->
      <div id="archive-groups" class="archive-groups">
        {yearGroups.map(([year, yearIssues]) => (
          <div class="year-group" data-year={year}>
            <h3 class="year-heading">
              <span class="year-rule" aria-hidden="true"></span>
              {year}
            </h3>
            <div class="year-issues">
              {yearIssues.map((issue) => (
                <a
                  href={issue.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`issue-card${issue.special ? ' issue-card--special' : ''}`}
                  data-issue={issue.no}
                  data-period={issue.period}
                  data-special={issue.special ? 'true' : 'false'}
                  data-search={`issue ${issue.no} ${issue.period} ${issue.special ? issue.specialNote ?? '' : ''}`.toLowerCase()}
                  aria-label={`Read Issue ${issue.no} (${issue.period}) PDF — opens in a new tab${issue.special ? '. Special edition.' : ''}`}
                >
                  {issue.special && (
                    <span class="ic-special-badge" aria-label="Special edition">
                      <svg width="9" height="9" viewBox="0 0 10 10" aria-hidden="true" focusable="false">
                        <polygon points="5,0 6.18,3.82 10,3.82 6.91,6.18 8.09,10 5,7.64 1.91,10 3.09,6.18 0,3.82 3.82,3.82" fill="currentColor"/>
                      </svg>
                      Special
                    </span>
                  )}
                  <span class="ic-number">{issue.no}</span>
                  <span class="ic-period">{issue.period}</span>
                  {issue.special && issue.specialNote && (
                    <span class="ic-note">{issue.specialNote}</span>
                  )}
                  <span class="ic-read" aria-hidden="true">
                    Read PDF
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="archive-footer">
        <a
          href="https://drive.google.com/drive/folders/1Z3a-TpO5AZx_Fzt68v2VTThk2jLYAMKs?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline"
          aria-label="Browse all issues in Google Drive — opens in a new tab"
