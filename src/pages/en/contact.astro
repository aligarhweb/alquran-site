---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contact Us"
  description="Get in touch with Idara Ulum-Al-Qur'an, Aligarh Muslim University, Aligarh, Uttar Pradesh, India."
>
  <main class="container page-content">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/en/">Home</a>
      <span>›</span>
      <span>Contact</span>
    </nav>

    <h1>Contact Us</h1>

    <div class="contact-grid">

      <div class="contact-info">

        <div class="info-card">
          <h2>Address</h2>
          <p>
            Idara Ulum-Al-Qur'an<br />
            Aligarh Muslim University<br />
            Aligarh, Uttar Pradesh<br />
            India — 202002
          </p>
        </div>

        <div class="info-card">
          <h2>Journal Subscription</h2>
          <p>
            <em>Ulum al-Qur'an</em> is published twice a year.
            To subscribe or inquire about back issues,
            please write to us at the address above or
            use the enquiry form on this page.
          </p>
          <a href="/en/journal/" class="btn-outline">Learn About the Journal →</a>
        </div>

        <div class="info-card">
          <h2>Follow Us</h2>
          <p>Watch seminar recordings and lecture series on our YouTube channel.</p>
          
            <a href="https://www.youtube.com/@idaraululmalquran"
            target="_blank"
            rel="noopener"
            class="btn-outline"
          >
            Visit YouTube Channel →
          </a>
        </div>

      </div>

      <div class="contact-form-wrap">
        <h2>Send an Enquiry</h2>
        <p class="form-note">Fill in the form below and we will get back to you as soon as possible.</p>

        <form
  class="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
>
  <input type="hidden" name="access_key" value="3e882619-4829-488b-a1ca-2f94ab4d52db" />
  <input type="hidden" name="subject" value="New Enquiry — Idara Ulum-Al-Qur'an Website" />
  <input type="hidden" name="from_name" value="alquran.in Contact Form" />
  <input type="checkbox" name="botcheck" style="display:none" />
          <div class="field">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" required placeholder="e.g. Ahmed Ali" />
          </div>

          <div class="field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" />
          </div>

          <div class="field">
            <label for="subject">Subject</label>
            <select id="subject" name="subject">
              <option value="">Select a topic</option>
              <option value="subscription">Journal Subscription</option>
              <option value="publication">Publications Enquiry</option>
              <option value="seminar">Seminars & Events</option>
              <option value="research">Research Collaboration</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required placeholder="Write your message here..."></textarea>
          </div>

          <button type="submit" class="btn-submit">Send Message</button>
        </form>
      </div>

    </div>

  </main>
</Layout>

<style>
.page-content {
  padding-top: 2.5rem;
  padding-bottom: 4rem;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: var(--color-muted);
  margin-bottom: 1.5rem;
}

.breadcrumb a {
  color: var(--color-link);
}

.breadcrumb a:hover {
  text-decoration: underline;
}

h1 {
  font-size: 2.25rem;
  color: var(--color-primary);
  margin-bottom: 2rem;
  padding-bottom: 1rem;
  border-bottom: 2px solid var(--color-border);
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 3rem;
  align-items: start;
}

/* ─── Info Cards ─── */
.info-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
}

.info-card h2 {
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-muted);
  margin-bottom: 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--color-border);
}

.info-card p {
  font-size: 0.95rem;
  line-height: 1.85;
  color: var(--color-text);
  margin-bottom: 1rem;
}

.info-card em {
  color: var(--color-primary);
  font-style: italic;
}

.btn-outline {
  display: inline-block;
  padding: 0.55rem 1.25rem;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 4px;
  font-size: 0.85rem;
  font-weight: 600;
  transition: background 0.2s, color 0.2s;
}

.btn-outline:hover {
  background: var(--color-primary);
  color: #FFFFFF;
  text-decoration: none;
}

/* ─── Form ─── */
.contact-form-wrap h2 {
  font-size: 1.4rem;
  color: var(--color-primary);
  margin-bottom: 0.5rem;
}

.form-note {
  font-size: 0.9rem;
  color: var(--color-muted);
  margin-bottom: 1.75rem;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.field label {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-text);
}

.field input,
.field select,
.field textarea {
  padding: 0.65rem 0.9rem;
  border: 1.5px solid var(--color-border);
  border-radius: 4px;
  font-size: 0.95rem;
  font-family: 'Source Serif 4', serif;
  background: var(--color-white);
  color: var(--color-text);
  transition: border-color 0.2s;
  width: 100%;
}

.field input:focus,
.field select:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--color-primary);
}

.field textarea {
  resize: vertical;
  min-height: 120px;
}

.btn-submit {
  padding: 0.75rem 2rem;
  background: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: 4px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Source Serif 4', serif;
  transition: opacity 0.2s;
  align-self: flex-start;
}

.btn-submit:hover {
  opacity: 0.88;
}

@media (max-width: 768px) {
  h1 {
    font-size: 1.75rem;
  }

  .contact-grid {
    display: block;
  }

  .contact-form-wrap {
    margin-top: 2rem;
  }

  .btn-submit {
    width: 100%;
  }
}
</style>