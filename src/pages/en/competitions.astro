<Layout
  title="Annual Essay Competitions"
  description="Since 2009, Idara Ulum-Al-Qur'an has organised a nationwide essay competition inviting students from madrasas and universities to engage with Qur'anic themes."
  canonicalUrl="/en/competitions/"
>
  <main class="container page-content">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/en/">Home</a>
      <span>›</span>
      <span>Competitions</span>
    </nav>

    <h1>Annual Essay Competitions</h1>

    <div class="intro-section">
      <p>
        Since 2009, Idara Ulum-Al-Qur'an has been organising a nationwide essay
        competition titled <strong>"Return to the Qur'an"</strong>. This initiative aims to:
      </p>
      <ul class="aims-list">
        <li>Attract students towards the Holy Qur'an by inspiring them to delve deeper into its teachings.</li>
        <li>Address non-Muslim concerns about the Qur'an and open the floor for constructive dialogue.</li>
        <li>Equip students to directly grasp the timeless and universal message of the Qur'an.</li>
      </ul>

      <div class="how-it-works">
        <h2>How It Works</h2>
        <ul class="how-list">
          <li>Students from madrasas and universities interested in research and writing are invited to participate.</li>
          <li>Each competition focuses on specific themes related to the Qur'an and its interpretations.</li>
          <li>Essays are judged by two independent expert referees assessing content, relevance, style, and source usage.</li>
          <li>To ensure anonymity, essays are coded and personal information is removed before evaluation.</li>
          <li>The Head of the Institute, after reviewing both referees' assessments, makes the final decision on winners.</li>
          <li>A committee oversees the entire process to ensure transparency and fairness.</li>
          <li>Each participant receives a participation certificate; winners are awarded cash prizes.</li>
        </ul>
      </div>

      <div class="participate-cta">
        <p>To participate in the upcoming competition or receive announcements, please contact us.</p>
        <a href="/en/contact/" class="btn-primary">Contact to Participate</a>
      </div>
    </div>

    <h2 class="results-heading">Previous Competitions & Results</h2>

    <div class="competitions-list">
      {competitions.map((comp) => (
        <details class="comp-item">
          <summary class="comp-summary">
            <div class="comp-year-badge">{comp.year}</div>
            <div class="comp-info">
              <span class="comp-edition">{comp.edition} Competition</span>
              <span class="comp-topic">{comp.topic}</span>
            </div>
            <span class="comp-arrow">›</span>
          </summary>

          <div class="comp-body">
            {comp.groups.map((group) => (
              <div class="group-section">
                <h3 class="group-name">{group.name}</h3>
                <table class="results-table">
                  <thead>
                    <tr>
                      <th>Prize</th>
                      <th>Name</th>
                      <th>Institution & Prize Amount</th>
                    </tr>
                  </thead>
                  <tbody>
                    {group.results.map((r) => (
                      <tr class={r.prize.startsWith('1st') ? 'row-gold' : r.prize.startsWith('2nd') ? 'row-silver' : r.prize.startsWith('3rd') ? 'row-bronze' : ''}>
                        <td class="td-prize">{r.prize}</td>
                        <td class="td-name">{r.name}</td>
                        <td class="td-inst">{r.institution}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ))}
          </div>
        </details>
      ))}
    </div>

  </main>
</Layout>

