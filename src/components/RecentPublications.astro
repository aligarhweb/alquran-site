---
const publications = [
  {
    title: "Khandani Nizam aur Qur'ani Ta'limat",
    titleEn: "Family System and Qur'anic Teachings",
    author: "Dr. Hamid al-Din Farahi",
    year: "2018",
    pages: "320",
    slug: "khandani-nizam"
  },
  {
    title: "Mabadi Tadabbur-i-Qur'an",
    titleEn: "Principles of Qur'anic Contemplation",
    author: "Amin Ahsan Islahi",
    year: "2016",
    pages: "280",
    slug: "mabadi-tadabbur"
  },
  {
    title: "Tajalli-e-Qur'an",
    titleEn: "The Manifestation of the Qur'an",
    author: "Idara Ulum-Al-Qur'an",
    year: "2014",
    pages: "210",
    slug: "tajalli-e-quran"
  }
];
---

<section class="publications-section">
  <div class="container">

    <div class="section-header">
      <h2 class="section-title">Recent Publications</h2>
      <a href="/en/publications/" class="section-link">View all publications →</a>
    </div>

    <div class="pub-grid">
      {publications.map((pub) => (
        <article class="pub-card">
          <div class="pub-cover">
            <span class="pub-cover-urdu">{pub.title.slice(0, 6)}</span>
          </div>
          <div class="pub-info">
            <h3 class="pub-title">
              <a href={`/en/publications/${pub.slug}/`}>{pub.title}</a>
            </h3>
            <p class="pub-title-en">{pub.titleEn}</p>
            <p class="pub-meta">{pub.author} · {pub.year} · {pub.pages} pages</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
.publications-section {
  padding: 4rem 0;
  background: var(--color-bg);
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 2rem;
  border-bottom: 2px solid var(--color-border);
  padding-bottom: 1rem;
}

.section-title {
  font-size: 1.5rem;
  color: var(--color-primary);
}

.section-link {
  font-size: 0.9rem;
  color: var(--color-link);
  font-weight: 600;
}

.section-link:hover {
  text-decoration: underline;
}

.pub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.pub-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}

.pub-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}

.pub-cover {
  background: linear-gradient(160deg, var(--color-primary) 0%, #0d3d32 100%);
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pub-cover-urdu {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1.5rem;
  color: var(--color-accent);
  line-height: 2;
}

.pub-info {
  padding: 1.25rem;
}

.pub-title {
  font-size: 1rem;
  margin-bottom: 0.35rem;
  line-height: 1.4;
}

.pub-title a {
  color: var(--color-primary);
}

.pub-title a:hover {
  text-decoration: underline;
}

.pub-title-en {
  font-size: 0.82rem;
  color: var(--color-muted);
  font-style: italic;
  margin-bottom: 0.75rem;
}

.pub-meta {
  font-size: 0.8rem;
  color: var(--color-muted);
}
@media (max-width: 768px) {
  .pub-grid {
    grid-template-columns: 1fr;
  }

  .pub-card {
    display: grid;
    grid-template-columns: 90px 1fr;
  }

  .pub-cover {
    height: auto;
    min-height: 110px;
  }

  .section-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }
}
</style>