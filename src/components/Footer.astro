---
const currentPath = Astro.url.pathname;
const isUrdu = currentPath.startsWith('/ur');

// English content
const en = {
  instituteName: "Idara Ulum-Al-Qur'an",
  address: "Aligarh Muslim University, Aligarh, Uttar Pradesh, India — 202002",
  quickLinks: "Quick Links",
  links: [
    { label: "About the Institute", href: "/en/about/" },
    { label: "Biannual Journal", href: "/en/journal/" },
    { label: "Publications", href: "/en/publications/" },
    { label: "Seminars", href: "/en/seminars/" },
    { label: "Competitions", href: "/en/competitions/" },
    { label: "Contact Us", href: "/en/contact/" },
  ],
  subscribeHeading: "Subscribe to Journal",
  subscribeText: "Ulum al-Qur'an is published twice a year. Contact us to subscribe.",
  ctaText: "Get in Touch",
  ctaHref: "/en/contact/",
  copyright: `© ${new Date().getFullYear()} Idara Ulum-Al-Qur'an, Aligarh Muslim University. All rights reserved.`,
};

// Urdu content
const ur = {
  instituteName: "ادارہ علوم القرآن",
  address: "علی گڑھ مسلم یونیورسٹی، علی گڑھ، اتر پردیش، انڈیا — ۲۰۲۰۰۲",
  quickLinks: "فوری روابط",
  links: [
    { label: "ادارہ کا تعارف", href: "/ur/about/" },
    { label: "ششماہی رسالہ", href: "/ur/journal/" },
    { label: "اشاعتیں", href: "/ur/publications/" },
    { label: "سیمینار", href: "/ur/seminars/" },
    { label: "مقابلے", href: "/ur/competitions/" },
    { label: "رابطہ کریں", href: "/ur/contact/" },
  ],
  subscribeHeading: "رسالہ کے لیے اشتراک",
  subscribeText: "علوم القرآن سال میں دو بار شائع ہوتا ہے۔ اشتراک کے لیے ہم سے رابطہ کریں۔",
  ctaText: "رابطہ کریں",
  ctaHref: "/ur/contact/",
  copyright: `© ${new Date().getFullYear()} ادارہ علوم القرآن، علی گڑھ مسلم یونیورسٹی۔ جملہ حقوق محفوظ ہیں۔`,
};

const content = isUrdu ? ur : en;
---

<footer class="site-footer" dir={isUrdu ? 'rtl' : 'ltr'}>
  <div class="container footer-inner">

    <div class="footer-col">
      <h3>{content.instituteName}</h3>
      <p>{content.address}</p>
    </div>

    <div class="footer-col">
      <h3>{content.quickLinks}</h3>
      <ul>
        {content.links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3>{content.subscribeHeading}</h3>
      <p>{content.subscribeText}</p>
      <a href={content.ctaHref} class="footer-cta">{content.ctaText}</a>
      <div class="social-links">
        <a href="https://www.youtube.com/@idaraululmalquran" target="_blank" rel="noopener">YouTube</a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>{content.copyright}</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background-color: var(--color-primary);
  color: rgba(255,255,255,0.85);
  margin-top: 4rem;
  padding-top: 3rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.15);
}

.footer-col h3 {
  color: var(--color-accent);
  font-size: 1rem;
  margin-bottom: 1rem;
}

/* Urdu headings use Nastaliq */
[dir="rtl"] .footer-col h3 {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1.1rem;
  line-height: 2;
}

.footer-col p {
  font-size: 0.9rem;
  line-height: 1.8;
  color: rgba(255,255,255,0.75);
}

[dir="rtl"] .footer-col p {
  font-family: 'Noto Nastaliq Urdu', serif;
  line-height: 2.2;
}

.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 0;
  margin: 0;
}

.footer-col ul a {
  color: rgba(255,255,255,0.75);
  font-size: 0.9rem;
  transition: color 0.2s;
  text-decoration: none;
}

[dir="rtl"] .footer-col ul a {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1rem;
  line-height: 2;
}

.footer-col ul a:hover {
  color: #FFFFFF;
  text-decoration: none;
}

.footer-cta {
  display: inline-block;
  margin-top: 1rem;
  padding: 0.5rem 1.25rem;
  background: var(--color-accent);
  color: #FFFFFF;
  border-radius: 4px;
  font-size: 0.9rem;
  font-weight: 600;
  transition: opacity 0.2s;
  text-decoration: none;
}

.footer-cta:hover {
  opacity: 0.85;
  text-decoration: none;
}

[dir="rtl"] .footer-cta {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1rem;
}

.social-links {
  margin-top: 1rem;
  display: flex;
  gap: 1rem;
}

.social-links a {
  color: rgba(255,255,255,0.7);
  font-size: 0.85rem;
  text-decoration: none;
}

.social-links a:hover {
  color: #FFFFFF;
  text-decoration: none;
}

.footer-bottom {
  padding: 1.25rem 0;
}

.footer-bottom p {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  text-align: center;
}

[dir="rtl"] .footer-bottom p {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 0.9rem;
}

@media (max-width: 768px) {
  .footer-inner {
    display: block;
  }

  .footer-col {
    margin-bottom: 2rem;
  }

  .footer-col h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .footer-col p,
  .footer-col ul a {
    font-size: 0.95rem;
  }

  [dir="rtl"] .footer-col p,
  [dir="rtl"] .footer-col ul a {
    font-size: 1rem;
  }

  .footer-cta {
    display: block;
    text-align: center;
    margin-top: 1rem;
  }

  .social-links {
    margin-top: 1rem;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    padding: 0 1rem;
  }
}
</style>