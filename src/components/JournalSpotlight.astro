---
---

<section class="journal-spotlight">
  <div class="container spotlight-inner">

    <div class="spotlight-badge">Latest Issue</div>

    <div class="spotlight-content">
      <div class="spotlight-meta">
        <span class="journal-title">Ulum al-Qur'an — علوم القرآن</span>
        <h2 class="spotlight-heading">Volume 39 · 2024</h2>
        <p class="spotlight-desc">The biannual peer-reviewed journal of Idara Ulum-Al-Qur'an, publishing original research in Qur'anic sciences, tafsir, and related disciplines since 1985.</p>
        <div class="spotlight-actions">
          <a href="/en/journal/" class="btn-primary">Read Online</a>
          <a href="/en/journal/subscribe/" class="btn-outline">Subscribe</a>
        </div>
      </div>

      <div class="spotlight-cover">
        <div class="cover-placeholder">
          <span class="cover-urdu">علوم القرآن</span>
          <span class="cover-vol">Vol. 39</span>
          <span class="cover-year">2024</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
.journal-spotlight {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  padding: 3.5rem 0;
}

.spotlight-inner {
  position: relative;
}

.spotlight-badge {
  display: inline-block;
  background: var(--color-accent);
  color: #FFFFFF;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.3rem 0.9rem;
  border-radius: 20px;
  margin-bottom: 1.5rem;
}

.spotlight-content {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: center;
}

.journal-title {
  display: block;
  font-size: 0.85rem;
  color: var(--color-muted);
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
}

.spotlight-heading {
  font-size: 2rem;
  color: var(--color-primary);
  margin-bottom: 1rem;
}

.spotlight-desc {
  font-size: 1rem;
  color: var(--color-muted);
  line-height: 1.8;
  max-width: 520px;
  margin-bottom: 1.75rem;
}

.spotlight-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-block;
  padding: 0.7rem 1.5rem;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.9rem;
  transition: opacity 0.2s;
}

.btn-primary:hover {
  opacity: 0.88;
  text-decoration: none;
}

.btn-outline {
  display: inline-block;
  padding: 0.7rem 1.5rem;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.9rem;
  transition: background 0.2s, color 0.2s;
}

.btn-outline:hover {
  background: var(--color-primary);
  color: #FFFFFF;
  text-decoration: none;
}

.cover-placeholder {
  width: 180px;
  height: 240px;
  background: linear-gradient(160deg, var(--color-primary) 0%, #0d3d32 100%);
  border-radius: 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  box-shadow: 0 8px 24px rgba(27,94,79,0.25);
}

.cover-urdu {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: 1.4rem;
  color: var(--color-accent);
  line-height: 2;
}

.cover-vol {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.8);
  font-weight: 600;
}

.cover-year {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.55);
}
</style>