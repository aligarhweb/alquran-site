<section class="about-strip">
  <div class="container about-inner">

    <div class="about-text">
      <h2>About the Institute</h2>
      <p>
        Idara Ulum-Al-Qur'an was established in 1984 at Aligarh Muslim University
        with the mission of advancing scholarly research in Qur'anic sciences.
        Following the intellectual tradition of Imam Hamid al-Din Farahi and his
        student Maulana Amin Ahsan Islahi, the institute publishes the peer-reviewed
        journal <em>Ulum al-Qur'an</em>, organises seminars, conducts competitions,
        and produces books and research papers on Qur'anic themes.
      </p>
      <a href="/en/about/" class="btn-outline">Read Full History →</a>
    </div>

    <div class="about-numbers">
      <div class="about-stat">
        <span class="about-num">1984</span>
        <span class="about-lbl">Founded at AMU</span>
      </div>
      <div class="about-stat">
        <span class="about-num">39</span>
        <span class="about-lbl">Journal Volumes</span>
      </div>
      <div class="about-stat">
        <span class="about-num">3</span>
        <span class="about-lbl">Languages</span>
      </div>
    </div>

  </div>
</section>

<style>
.about-strip {
  background: var(--color-white);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 4rem 0;
}

.about-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
}

.about-text h2 {
  font-size: 1.75rem;
  color: var(--color-primary);
  margin-bottom: 1rem;
}

.about-text p {
  font-size: 1rem;
  line-height: 1.85;
  color: var(--color-muted);
  max-width: 580px;
  margin-bottom: 1.5rem;
}

.about-text em {
  color: var(--color-primary);
  font-style: italic;
}

.btn-outline {
  display: inline-block;
  padding: 0.65rem 1.4rem;
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.9rem;
  transition: background 0.2s, color 0.2s;
}

.btn-outline:hover {
  background: var(--color-primary);
  color: #FFFFFF;
  text-decoration: none;
}

.about-numbers {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  border-left: 2px solid var(--color-border);
  padding-left: 3rem;
}

.about-stat {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.about-num {
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.about-lbl {
  font-size: 0.8rem;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
@media (max-width: 768px) {
  .about-inner {
    display: block;
  }

  .about-text h2 {
    font-size: 1.4rem;
  }

  .about-text p {
    font-size: 0.95rem;
  }

  .about-numbers {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    border-left: none;
    padding-left: 0;
    border-top: 2px solid var(--color-border);
    margin-top: 2rem;
    padding-top: 1.5rem;
    gap: 1.5rem;
  }

  .about-stat {
    flex: 1 1 calc(33% - 1rem);
    min-width: 80px;
  }

  .about-num {
    font-size: 1.75rem;
  }

  .about-lbl {
    font-size: 0.72rem;
  }
}

</style>