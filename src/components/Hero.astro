<section class="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="hero-eyebrow">Established 1984 · Aligarh Muslim University</p>
      <h1 class="hero-heading">Four Decades of<br />Qur'anic Scholarship</h1>
      <p class="hero-sub">Idara Ulum-Al-Qur'an is an independent academic institute dedicated to research, teaching, and publication in the field of Qur'anic sciences, following the methodology of Imam Hamid al-Din Farahi.</p>
      <div class="hero-actions">
        <a href="/en/journal/" class="btn-primary">Explore the Journal</a>
        <a href="/en/publications/" class="btn-secondary">Browse Publications</a>
      </div>
    </div>

    <div class="hero-stats">
      <div class="stat-card">
        <span class="stat-number">39</span>
        <span class="stat-label">Journal Volumes</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">40+</span>
        <span class="stat-label">Years of Research</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">1984</span>
        <span class="stat-label">Year Founded</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  background: linear-gradient(135deg, var(--color-primary) 0%, #0d3d32 100%);
  color: #FFFFFF;
  padding: 5rem 0 4rem;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: center;
}

.hero-eyebrow {
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  color: var(--color-accent);
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.hero-heading {
  font-size: 3rem;
  color: #FFFFFF;
  line-height: 1.15;
  margin-bottom: 1.5rem;
}

.hero-sub {
  font-size: 1.05rem;
  line-height: 1.8;
  color: rgba(255,255,255,0.82);
  max-width: 560px;
  margin-bottom: 2rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  background: var(--color-accent);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.95rem;
  transition: opacity 0.2s;
}

.btn-primary:hover {
  opacity: 0.88;
  text-decoration: none;
}

.btn-secondary {
  display: inline-block;
  padding: 0.75rem 1.75rem;
  border: 2px solid rgba(255,255,255,0.5);
  color: #FFFFFF;
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.95rem;
  transition: border-color 0.2s, background 0.2s;
}

.btn-secondary:hover {
  border-color: #FFFFFF;
  background: rgba(255,255,255,0.08);
  text-decoration: none;
}

.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.stat-card {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  padding: 1.25rem 2rem;
  text-align: center;
  min-width: 160px;
}

.stat-number {
  display: block;
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--color-accent);
  line-height: 1;
  margin-bottom: 0.4rem;
}

.stat-label {
  display: block;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.7);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
</style>